# ─── archive-mirror configuration ────────────────────────────────────────────
# Copy this file to .env and edit the values before running docker compose up.

# ── Collection ─────────────────────────────────────────────────────────────
# Internet Archive collection identifier to mirror.
COLLECTION=aadamjacobs

# ── Paths (inside the container — mapped via Docker volumes) ───────────────
OUTPUT_DIR=/data/music
STATE_DIR=/data/state

# ── Scheduling ─────────────────────────────────────────────────────────────
# How often to run a sync, in seconds.
# 3600  = every hour (default)
# 86400 = once a day
# 0     = run once then exit
SYNC_INTERVAL=3600

# ── Concurrency ─────────────────────────────────────────────────────────────
# Maximum number of tracks downloading simultaneously.
# Keep low (2–5) to be a good citizen on Internet Archive.
CONCURRENCY=3

# Seconds to wait between HTTP requests per worker (additional throttle).
RATE_LIMIT_DELAY=1.0

# ── HTTP behaviour ──────────────────────────────────────────────────────────
# Per-request timeout in seconds.
REQUEST_TIMEOUT=120

# Maximum retry attempts per download or metadata fetch.
RETRY_COUNT=5

# ── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Behaviour flags ─────────────────────────────────────────────────────────
# Set to true to list what would be downloaded without writing any files.
DRY_RUN=false

# Write checksums.md5 manifest to each concert folder after download.
CHECKSUM_MANIFEST=true

# ── Notifications (optional) ────────────────────────────────────────────────
# POST a JSON summary to this URL at the end of each sync.
# Leave blank to disable.
WEBHOOK_URL=

# ── Health endpoint ──────────────────────────────────────────────────────────
HEALTH_PORT=8080
